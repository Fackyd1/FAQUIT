{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Vite Dev Server",
            "type": "shell",
            "command": "npm.cmd",
            "args": ["run", "dev", "--prefix", "client"],
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^(.*)$",
                    "file": 1,
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*",
                    "endsPattern": "http://localhost:5173"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
